# ============================================
# AdForge AI — Variables d'environnement
# ============================================
# Copiez ce fichier en .env.local et remplissez les valeurs.
# Ne commitez JAMAIS le fichier .env.local.

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- Auth (Clerk) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ---- Database (Neon PostgreSQL) ----
DATABASE_URL=postgresql://user:password@host/adforge_ai?sslmode=require

# ---- Redis (Upstash) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Storage (Cloudflare R2) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=adforge-ai-assets
R2_PUBLIC_URL=

# ---- AI Providers ----
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ---- FLUX (Black Forest Labs — photoréaliste premium) ----
FLUX_API_KEY=
FLUX_BASE_URL=https://api.bfl.ml/v1
ENABLE_FLUX=true

# ---- Ideogram (texte intégré / poster / branding) ----
IDEOGRAM_API_KEY=
IDEOGRAM_BASE_URL=https://api.ideogram.ai
ENABLE_IDEOGRAM=true

# ---- Image Provider Routing ----
DEFAULT_IMAGE_PROVIDER=openai
IMAGE_PROVIDER_FALLBACK=openai

# ---- Payments (Stripe) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_STUDIO_PRICE_ID=

# ---- Payments (CinetPay) ----
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_NOTIFY_URL=

# ---- Observability ----
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
